            card_mod:
              style:
                ha-markdown$: |
                  h1 {
                    text-align: center;
                    font-size: 22px;
                    margin-bottom: 18px;
                    color: #ffffff;
                    text-shadow:
                      0 0 8px rgba(0,255,255,0.9),
                      0 0 18px rgba(0,255,255,0.55);
                  }

                  .scorer-row {
                    display: grid;
                    grid-template-columns: 42px 1fr 90px 58px;
                    align-items: center;
                    gap: 8px;
                    margin: 8px 0;
                    padding: 10px 12px;
                    border-radius: 14px;
                    background: rgba(0,255,255,0.07);
                    border: 1px solid rgba(0,255,255,0.18);
                  }

                  .rank {
                    font-size: 18px;
                    text-align: center;
                  }

                  .player {
                    font-weight: 700;
                    color: #ffffff;
                  }

                  .team {
                    font-size: 12px;
                    color: rgba(255,255,255,0.7);
                    text-align: right;
                  }

                  .goals {
                    font-weight: 800;
                    color: #00ffff;
                    text-align: right;
                    text-shadow: 0 0 8px rgba(0,255,255,0.7);
                  }
                .: |
                  ha-card {
                    background: rgba(5,14,24,0.38) !important;
                    backdrop-filter: blur(10px);
                    border-radius: 24px;
                    border: 2px solid rgba(0,255,255,0.38);
                    box-shadow:
                      0 0 20px rgba(0,255,255,0.25),
                      inset 0 0 14px rgba(0,255,255,0.08);
                    padding: 14px;
                    overflow: hidden;
                  }
