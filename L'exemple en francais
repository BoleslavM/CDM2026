  - type: sections
    max_columns: 4
    title: France
    path: france
    sections:
      - type: grid
        cards:
          - type: markdown
            title: null
            content: >
              {%- set TEAM = 'France' -%}

              {%- set codes = {
                'argentina':'ar','australia':'au','austria':'at','belgium':'be','brazil':'br','canada':'ca',
                'colombia':'co','costa rica':'cr','croatia':'hr','czechia':'cz','denmark':'dk','ecuador':'ec',
                'egypt':'eg','england':'gb-eng','france':'fr','germany':'de','ghana':'gh','iran':'ir','italy':'it',
                'ivory coast':'ci','jamaica':'jm','japan':'jp','south korea':'kr','korea republic':'kr','mexico':'mx',
                'morocco':'ma','netherlands':'nl','new zealand':'nz','nigeria':'ng','norway':'no','panama':'pa',
                'paraguay':'py','poland':'pl','portugal':'pt','qatar':'qa','saudi arabia':'sa','scotland':'gb-sct',
                'senegal':'sn','serbia':'rs','south africa':'za','spain':'es','sweden':'se','switzerland':'ch',
                'tunisia':'tn','turkey':'tr','ukraine':'ua','uruguay':'uy','united states':'us','usa':'us',
                'wales':'gb-wls','algeria':'dz','cape verde':'cv','dr congo':'cd','cameroon':'cm','mali':'ml',
                'burkina faso':'bf','uzbekistan':'uz','jordan':'jo','iraq':'iq','united arab emirates':'ae','uae':'ae',
                'oman':'om','china':'cn','bolivia':'bo','venezuela':'ve','peru':'pe','chile':'cl','el salvador':'sv',
                'trinidad and tobago':'tt','guatemala':'gt','ireland':'ie','romania':'ro','slovakia':'sk',
                'slovenia':'si','albania':'al','greece':'gr','georgia':'ge','hungary':'hu'
              } -%}

              {%- macro flag(name, h=14) -%}

              {%- set c = codes.get((name|string|lower|trim), '') -%}

              {%- if c -%}<img src="https://flagcdn.com/w40/{{ c }}.png"
              height="{{ h }}"
              style="vertical-align:middle;border-radius:3px;margin:0 4px;">{%-
              else -%}🏳️{%- endif -%}

              {%- endmacro -%}

              {%- set allm = state_attr('sensor.calendrier','matches') or [] -%}

              {%- set ns = namespace(fr=[], live=[], played=[], next=none,
              row=none, grp=none) -%}

              {%- for m in allm -%}

              {%- if m.home == TEAM or m.away == TEAM -%}{%- set ns.fr = ns.fr +
              [m] -%}{%- endif -%}

              {%- endfor -%}

              {%- set ns.fr = ns.fr | sort(attribute='utcDate') -%}

              {%- for m in ns.fr -%}

              {%- if m.status in ['IN_PLAY','PAUSED'] -%}{%- set ns.live =
              ns.live + [m] -%}{%- endif -%}

              {%- if m.status == 'FINISHED' -%}{%- set ns.played = ns.played +
              [m] -%}{%- endif -%}

              {%- if ns.next is none and m.status in ['SCHEDULED','TIMED']
              -%}{%- set ns.next = m -%}{%- endif -%}

              {%- endfor -%}

              {%- set st = state_attr('sensor.classements','standings') or []
              -%}

              {%- for g in st -%}{%- for t in g.table -%}{%- if t.team == TEAM
              -%}{%- set ns.row = t -%}{%- set ns.grp = g.group -%}{%- endif
              -%}{%- endfor -%}{%- endfor -%}

              {%- set grp = (ns.grp | replace('GROUP_','')) if ns.grp else '?'
              -%}

              ## {{ flag(TEAM, 22) }} Allez les Bleus !


              {% if ns.live | length > 0 -%}

              ### 🔴 EN DIRECT

              {% for m in ns.live %}- {{ flag(m.home) }} {{ m.home }} **{{
              m.homeScore }} - {{ m.awayScore }}** {{ m.away }} {{ flag(m.away)
              }} · {{ m.minute }}'

              {% endfor %}

              {% endif -%}


              ### ⏭️ Prochain match

              {% if ns.next -%}

              {{ flag(ns.next.home) }} **{{ ns.next.home }}** vs **{{
              ns.next.away }}** {{ flag(ns.next.away) }}


              🗓️ {{ as_timestamp(ns.next.utcDate) | timestamp_custom('%d/%m/%Y
              · %H:%M') }} &nbsp; 🏟️ {{ ns.next.venue }} ({{ ns.next.venueCity
              }})

              {%- else -%}

              Aucun match programmé pour l'instant.

              {%- endif %}


              ### 📊 Groupe {{ grp }}

              {% if ns.row -%}

              | Pos | Pts | J | V | N | D | BP | BC | Diff |

              |:---:|:---:|:-:|:-:|:-:|:-:|:--:|:--:|:----:|

              | **{{ ns.row.position }}** | **{{ ns.row.points }}** | {{
              ns.row.playedGames }} | {{ ns.row.won }} | {{ ns.row.draw }} | {{
              ns.row.lost }} | {{ ns.row.goalsFor }} | {{ ns.row.goalsAgainst }}
              | {{ ns.row.goalDifference }} |


              Forme : {{ ns.row.form if ns.row.form else '—' }}

              {%- else -%}

              Classement pas encore disponible.

              {%- endif %}


              ### ✅ Résultats

              {% if ns.played | length > 0 -%}

              {% for m in ns.played %}- {{ flag(m.home) }} {{ m.home }} **{{
              m.homeScore }} - {{ m.awayScore }}** {{ m.away }} {{ flag(m.away)
              }}

              {% endfor %}

              {%- else -%}

              Aucun match joué pour l'instant.

              {%- endif %}
