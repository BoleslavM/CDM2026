                <tr><td>🚀 Highest Scoring Match</td><td>{{ states('sensor.match_le_plus_prolifique') }}</td></tr>
                <tr><td>📰 Latest Result</td><td>{{ states('sensor.dernier_resultat') }}</td></tr>
                <tr><td>👟 {{ T.get('top_scorer','Top Scorer') }}</td><td>{{ states('sensor.meilleur_buteur') }}</td></tr>
                <tr><td>🎯 {{ T.get('top_assist','Top Assist') }}</td><td>{{ states('sensor.meilleur_passeur') }}</td></tr>
                <tr><td>⚽ Top Scoring Team</td><td>{{ states('sensor.equipe_la_plus_prolifique') }}</td></tr>
                <tr><td>🛡️ Best Defence</td><td>{{ states('sensor.meilleure_defense') }}</td></tr>
              </table>
